APP_ENV=development
APP_NAME=eldercare-platform
API_PORT=8000
WEB_PORT=3000

POSTGRES_DB=eldercare
POSTGRES_USER=eldercare_user
POSTGRES_PASSWORD=eldercare_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://eldercare_user:eldercare_pass@postgres:5432/eldercare
DATABASE_READ_URL=postgresql+psycopg://eldercare_user:eldercare_pass@postgres:5432/eldercare
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
SLOW_QUERY_BUDGET_MS=200

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-too
JWT_SIGNING_KEYS=v1:change-me
JWT_REFRESH_SIGNING_KEYS=v1:change-me-too
JWT_ACTIVE_KID=v1
JWT_REFRESH_ACTIVE_KID=v1
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_RATE_LIMIT_PER_MINUTE=60
SOS_RATE_LIMIT_PER_MINUTE=30
CSRF_PROTECTED_PATHS=/api/v1/auth,/api/v1/consent,/api/v1/health-records
SECRET_MANAGER_PROVIDER=env
SECRET_MANAGER_KMS_KEY_REF=

CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=eldercare-docs
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REQUIRE_TLS=false
POSTGRES_SSL_MODE=disable
