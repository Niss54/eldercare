{
  "name": "eldercare-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "openapi:pull": "node ./scripts/pull-openapi.mjs",
    "openapi:types": "openapi-typescript ./openapi/openapi.json -o ./lib/sdk/schema.ts",
    "sdk:generate": "npm run openapi:pull ; npm run openapi:types",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "14.2.17",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.6.3",
    "@types/node": "22.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.17",
    "jsdom": "25.0.1",
    "openapi-typescript": "7.8.0",
    "vitest": "2.1.8"
  }
}
